    "reply": {
      "subject": "Ответ на ваше письмо",
      "body": "<div><h3>Спасибо за ответ, {name}!</h3><p>Вот наше предложение:</p><p><strong>Цена: {price}</strong></p><a href='{link}' style='background:#238636;color:white;padding:10px 20px;text-decoration:none;border-radius:6px;display:inline-block;'>Посмотреть предложение</a></div>",
      "is_html": true
    }
  },
